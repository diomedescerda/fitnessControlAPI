-- =====================================================
-- SAMPLE DATA INSERTION
-- =====================================================

INSERT INTO muscle_groups (name) VALUES
    ('Chest'), ('Back'), ('Shoulders'), ('Biceps'), ('Triceps'),
    ('Quadriceps'), ('Hamstrings'), ('Glutes'), ('Calves'), ('Abs'),
    ('Forearms'), ('Traps'), ('Lats'), ('Lower Back'), ('Adductors'),
    ('Serratus Anterior'), ('Rhomboids'), ('Brachialis'), ('Hip Flexors')
ON CONFLICT (name) DO NOTHING;

-- Insert default categories
INSERT INTO exercise_categories (name, description) VALUES
    ('Push', 'Focuses on chest, shoulders, and triceps'),
    ('Pull', 'Targets the back and biceps'),
    ('Legs', 'Covers quadriceps, hamstrings, glutes, and calves');

-- =====================================================
-- CHEST EXERCISES
-- =====================================================

-- Incline Barbell Bench Press
INSERT INTO exercises (name, description, category_id) 
SELECT 'Incline Barbell Bench Press', 'Barbell bench press on incline bench', id 
FROM exercise_categories WHERE name = 'Push';

-- Primary: Chest (Upper), Secondary: Triceps, Shoulders
WITH exercise_id AS (SELECT id FROM exercises WHERE name = 'Incline Barbell Bench Press')
INSERT INTO exercise_muscle_groups (exercise_id, muscle_group_id, is_primary)
SELECT (SELECT id FROM exercise_id), mg.id, 
       mg.name = 'Chest'  -- Primary if Chest
FROM muscle_groups mg 
WHERE mg.name IN ('Chest', 'Triceps', 'Shoulders');

-- Pec Deck (Machine Fly)
INSERT INTO exercises (name, description, category_id) 
SELECT 'Pec Deck', 'Machine chest fly', id 
FROM exercise_categories WHERE name = 'Push';

WITH exercise_id AS (SELECT id FROM exercises WHERE name = 'Pec Deck')
INSERT INTO exercise_muscle_groups (exercise_id, muscle_group_id, is_primary)
SELECT (SELECT id FROM exercise_id), mg.id, 
       mg.name = 'Chest'
FROM muscle_groups mg 
WHERE mg.name IN ('Chest', 'Shoulders', 'Biceps');

