-- =====================================================
-- TRICEPS EXERCISES
-- =====================================================

-- Skull Crusher (Lying Triceps Extension)
INSERT INTO exercises (name, description, category_id) 
SELECT 'Skull Crusher', 'Lying triceps extension with EZ-bar or dumbbells', id 
FROM exercise_categories WHERE name = 'Push';

WITH exercise_id AS (SELECT id FROM exercises WHERE name = 'Skull Crusher')
INSERT INTO exercise_muscle_groups (exercise_id, muscle_group_id, is_primary)
SELECT (SELECT id FROM exercise_id), mg.id, 
       mg.name = 'Triceps'
FROM muscle_groups mg 
WHERE mg.name IN ('Triceps', 'Chest');

-- Rope Pushdown
INSERT INTO exercises (name, description, category_id) 
SELECT 'Rope Pushdown', 'Cable triceps pushdown with rope attachment', id 
FROM exercise_categories WHERE name = 'Push';

WITH exercise_id AS (SELECT id FROM exercises WHERE name = 'Rope Pushdown')
