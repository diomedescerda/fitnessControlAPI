WHERE mg.name IN ('Triceps');

-- =====================================================
-- BACK EXERCISES
-- =====================================================

-- Lat Pulldown
INSERT INTO exercises (name, description, category_id) 
SELECT 'Lat Pulldown', 'Cable pulldown to chest or behind neck', id 
FROM exercise_categories WHERE name = 'Pull';

WITH exercise_id AS (SELECT id FROM exercises WHERE name = 'Lat Pulldown')
INSERT INTO exercise_muscle_groups (exercise_id, muscle_group_id, is_primary)
SELECT (SELECT id FROM exercise_id), mg.id, 
       mg.name = 'Lats'
FROM muscle_groups mg 
WHERE mg.name IN ('Lats', 'Back', 'Biceps', 'Rhomboids');

-- Deficit Pendlay Row
INSERT INTO exercises (name, description, category_id) 
SELECT 'Deficit Pendlay Row', 'Barbell row from floor with deficit', id 
FROM exercise_categories WHERE name = 'Pull';

WITH exercise_id AS (SELECT id FROM exercises WHERE name = 'Deficit Pendlay Row')
INSERT INTO exercise_muscle_groups (exercise_id, muscle_group_id, is_primary)
SELECT (SELECT id FROM exercise_id), mg.id, 
       mg.name = 'Back'
FROM muscle_groups mg 
WHERE mg.name IN ('Back', 'Lats', 'Rhomboids', 'Traps', 'Lower Back', 'Biceps');

